# ════════════════════════════════════════
# EcoBin Web App — Environment Variables
# ════════════════════════════════════════
# Copy this file to .env.local and fill in your values:
#   cp .env.local.example .env.local

# Supabase Project URL (from Supabase Dashboard → Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Supabase Anon/Public Key (safe for browser — enforces RLS)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Supabase Service Role Key (SERVER ONLY — bypasses RLS, never expose to browser!)
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# Secret key that the ESP32 sends in x-api-key header to authenticate API calls
# NOTE: This is NOT used directly — each bin gets its own auto-generated api_key
# in the database when registered via /api/bins/register.
# This env var is kept for legacy/testing purposes.
API_SECRET_KEY=your_esp32_api_secret_here

# Secret for the Vercel Cron job that marks bins offline (/api/mark-offline)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# On Vercel: Set this in Project Settings → Environment Variables
# The cron job sends this as the x-cron-secret header
CRON_SECRET=your_cron_secret_here
